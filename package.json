{
  "name": "@espace-tech/auth",
  "version": "0.2.0",
  "description": "Client-side auth SDK for apps built on Espace-Tech Cloud Auth",
  "author": "Espace-Tech <hello@espace-tech.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "espace-tech",
    "auth",
    "authentication",
    "login",
    "oauth",
    "jwt",
    "paas"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bz-reda/ETC-Auth-SDK"
  },
  "homepage": "https://cloud.espace-tech.com/docs",
  "engines": {
    "node": ">=18.0.0"
  }
}
